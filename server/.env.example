PORT=3001
CLIENT_URL=http://localhost:5173

FB_ACCESS_TOKEN=                       # System User token from Business Manager (ads_read)
FB_AD_ACCOUNTS=act_XXXXX,act_YYYYY     # comma-separated, one per ad account

GHL_API_KEY=                           # Go High Level API key (Settings → Integrations → API Keys)

# Hyros
HYROS_API_KEY=API_382d3fc2351f0eae5bb04da63f5005e453d805d569eaad836636258c35d5f652
HYROS_AD_ACCOUNTS=1125965718442560,758516163121709   # comma-separated FB ad account IDs tracked in Hyros
HYROS_SHEET_OWNER=levi@cypressmediagroup.com         # Google account to share the sheet with

# Per-account lead field (run /api/hyros/probe to find the right name for each account)
# HYROS_LEADS_FIELD=leads                            # global fallback (default: leads)
# HYROS_LEADS_FIELD_1125965718442560=leads_b2c_ppl   # override for account 1125965718442560
# HYROS_LEADS_FIELD_758516163121709=leads_zemsky      # override for account 758516163121709

GOOGLE_SERVICE_ACCOUNT_JSON=
SHEETS_ID=                            # from the spreadsheet URL
SHEETS_TAB_NAME=Sheet1
SHEETS_STATE_COL=D                    # column containing state abbreviations (e.g. VA, GA)

# ── Digest (twice-daily ops summary → Telegram) ──────────────────────────────
# Create a bot with @BotFather, get your chat id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Send times in DIGEST_TZ (comma-separated), or "off" to disable the schedule
DIGEST_TIMES=07:30,16:00
DIGEST_TZ=America/Los_Angeles

# Write token for kill commands — from a SEPARATE unpublished dev-mode app
# with ads_management (published read app stays ads_read only)
FB_WRITE_TOKEN=
